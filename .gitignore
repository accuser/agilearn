# =============================================================================
# Agilearn — .gitignore
# =============================================================================

# ----- MkDocs build output ---------------------------------------------------
site/

# ----- JupyterLite build artefacts (kept out of source control) --------------
.jupyterlite.doit.db
jupyterlite/_output/
jupyterlite/.jupyterlite.doit.db

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ----- Test / lint caches ----------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ----- Jupyter ---------------------------------------------------------------
.ipynb_checkpoints/

# ----- Cloudflare / Wrangler -------------------------------------------------
.wrangler/
.dev.vars
.dev.vars.*

# ----- Node (in case JS tooling sneaks in) -----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Editor / OS cruft -----------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Local secrets / env ---------------------------------------------------
.env
.env.local
.env.*.local

# ----- MkDocs cache ----------------------------------------------------------
.cache/
